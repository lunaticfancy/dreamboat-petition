# Environment variables for Puruni Web Application
# Copy this file to .env and fill in the values

# ============================================
# Database
# ============================================
DATABASE_URL="file:./dev.db"

# ============================================
# NextAuth Configuration
# ============================================
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# Push Notifications (VAPID Keys)
# ============================================
VAPID_PUBLIC_KEY="BM6ijMAop4ui4fRI2K4OmTx4UCwHwuKCucsnwQjcolz4bvFDXsKcnmW56qxggnHyB20Y-MY_eU2IMeVxqae3h5c"
VAPID_PRIVATE_KEY="ZtZZCgZ1iT_LI2gjpxBJOXU9laxiRpoOHDRboJlSYPc"
NEXT_PUBLIC_VAPID_KEY="BM6ijMAop4ui4fRI2K4OmTx4UCwHwuKCucsnwQjcolz4bvFDXsKcnmW56qxggnHyB20Y-MY_eU2IMeVxqae3h5c"

# ============================================
# Email Configuration
# ============================================
# Provider: "smtp" | "sendgrid" | "mock"
# If not set, auto-detects based on available credentials
# Defaults to "mock" in development, "smtp" in production
EMAIL_PROVIDER=smtp

# SMTP Configuration (for EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=푸르니

# SendGrid Configuration (for EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=푸르니