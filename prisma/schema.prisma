generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                     String             @id @default(cuid())
  email                  String             @unique
  password               String
  name                   String?
  role                   String             @default("PARENT")
  isVerified             Boolean            @default(false)
  verifiedAt             DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  notifyNewPetition      Boolean            @default(true)
  notifyNewReport        Boolean            @default(true)
  notifyThresholdReached Boolean            @default(true)
  agreements             Agreement[]
  answers                Answer[]
  comments               Comment[]
  petitions              Petition[]
  pushSubscriptions      PushSubscription[]
  reports                Report[]
  adminSettings          Setting[]
  verificationCodes      VerificationCode[]

  @@index([email])
  @@index([role])
}

model Petition {
  id          String       @id @default(cuid())
  title       String
  content     String
  status      String       @default("OPEN")
  anonymousId String       @unique @default(cuid())
  agreedCount Int          @default(0)
  threshold   Int          @default(10)
  isHidden    Boolean      @default(false)
  mergedToId  String?
  authorId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  answeredAt  DateTime?
  closedAt    DateTime?
  mergedAt    DateTime?
  agreements  Agreement[]
  answers     Answer[]
  comments    Comment[]
  files       FileUpload[]
  author      User?        @relation(fields: [authorId], references: [id])
  mergedTo    Petition?    @relation("MergedPetitions", fields: [mergedToId], references: [id])
  mergedFrom  Petition[]   @relation("MergedPetitions")
  reports     Report[]

  @@index([status])
  @@index([agreedCount])
  @@index([createdAt])
  @@index([mergedToId])
  @@index([isHidden])
  @@index([authorId])
}

model Agreement {
  id           String   @id @default(cuid())
  userId       String
  petitionId   String
  anonymousKey String
  createdAt    DateTime @default(now())
  petition     Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, petitionId])
  @@index([petitionId])
  @@index([anonymousKey])
}

model Comment {
  id         String    @id @default(cuid())
  content    String
  userId     String
  petitionId String
  parentId   String?
  isStaff    Boolean   @default(false)
  staffRole  String?
  ipAddress  String?
  isHidden   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")
  petition   Petition  @relation(fields: [petitionId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports    Report[]

  @@index([petitionId])
  @@index([parentId])
  @@index([createdAt])
  @@index([isHidden])
}

model Answer {
  id          String              @id @default(cuid())
  content     String
  authorId    String
  petitionId  String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  petition    Petition            @relation(fields: [petitionId], references: [id], onDelete: Cascade)
  author      User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  editHistory AnswerEditHistory[]

  @@index([petitionId])
  @@index([authorId])
}

model AnswerEditHistory {
  id              String   @id @default(cuid())
  answerId        String
  previousContent String
  editedAt        DateTime @default(now())
  answer          Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@index([answerId])
  @@index([editedAt])
}

model Report {
  id          String    @id @default(cuid())
  petitionId  String?
  commentId   String?
  reporterId  String
  reason      String
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  reporter    User      @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  comment     Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  petition    Petition? @relation(fields: [petitionId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([reporterId])
}

model VerificationCode {
  id        String    @id @default(cuid())
  code      String
  userId    String
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([code, userId])
  @@index([expiresAt])
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedById String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  updatedBy   User?    @relation(fields: [updatedById], references: [id])

  @@index([key])
}

model FileUpload {
  id         String   @id @default(cuid())
  url        String
  fileName   String
  fileType   String
  fileSize   Int
  petitionId String
  uploadedAt DateTime @default(now())
  petition   Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)

  @@index([petitionId])
}

model PushSubscription {
  id        String    @id @default(cuid())
  userId    String
  endpoint  String    @unique
  p256dh    String
  auth      String
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
